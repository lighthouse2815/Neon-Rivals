{
  "name": "@neon-duel/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --clean --sourcemap",
    "start": "node dist/index.js",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@neon-duel/shared": "workspace:*",
    "fastify": "^5.4.0",
    "socket.io": "^4.8.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "socket.io-client": "^4.8.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3"
  }
}
